{% doc %}
  @prompt
    Large text bar saying in bold STEP 2: and In normal CUSTOMIZE YOUR BRACELET
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-step-bar-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-step-bar__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    margin: 0;
    line-height: 1.4;
  }

  .ai-step-bar__bold-{{ ai_gen_id }} {
    font-weight: 700;
  }

  .ai-step-bar__normal-{{ ai_gen_id }} {
    font-weight: 400;
  }

  @media screen and (max-width: 749px) {
    .ai-step-bar__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-step-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <p class="ai-step-bar__text-{{ ai_gen_id }}">
    <span class="ai-step-bar__bold-{{ ai_gen_id }}">{{ block.settings.bold_text }}</span>
    <span class="ai-step-bar__normal-{{ ai_gen_id }}">{{ block.settings.normal_text }}</span>
  </p>
</div>

{% schema %}
{
  "name": "Step text bar",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "bold_text",
      "label": "Bold text",
      "default": "STEP 2:"
    },
    {
      "type": "text",
      "id": "normal_text",
      "label": "Normal text",
      "default": " CUSTOMIZE YOUR BRACELET"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Step text bar"
    }
  ]
}
{% endschema %}
