{% doc %}
  @prompt
    Large text bar saying in bold STEP 1: and In normal CHOOSE YOUR BRACELET
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-bar-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-bar__content-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.4;
  }

  .ai-text-bar__bold-{{ ai_gen_id }} {
    font-weight: {{ block.settings.bold_font.weight }};
    font-family: {{ block.settings.bold_font.family }}, {{ block.settings.bold_font.fallback_families }};
  }

  @media screen and (max-width: 749px) {
    .ai-text-bar-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-text-bar__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-text-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-bar__content-{{ ai_gen_id }}">
    <span class="ai-text-bar__bold-{{ ai_gen_id }}">{{ block.settings.bold_text }}</span> {{ block.settings.normal_text }}
  </div>
</div>

{% schema %}
{
  "name": "Text bar",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "bold_text",
      "label": "Bold text",
      "default": "STEP 1:"
    },
    {
      "type": "text",
      "id": "normal_text",
      "label": "Normal text",
      "default": "CHOOSE YOUR BRACELET"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "font_picker",
      "id": "bold_font",
      "label": "Bold font",
      "default": "poppins_n7"
    },
    {
      "type": "font_picker",
      "id": "text_font",
      "label": "Normal font",
      "default": "poppins_n5"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Text bar"
    }
  ]
}
{% endschema %}
