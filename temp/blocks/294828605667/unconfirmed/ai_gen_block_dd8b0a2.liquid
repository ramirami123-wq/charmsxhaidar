{% doc %}
  @prompt
    Scrolling header
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scrolling-header-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
  }

  .ai-scrolling-header__wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
    animation: ai-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-scrolling-header__item-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
    white-space: nowrap;
  }

  .ai-scrolling-header__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-transform: {{ block.settings.text_transform }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  .ai-scrolling-header__separator-{{ ai_gen_id }} {
    width: {{ block.settings.separator_size }}px;
    height: {{ block.settings.separator_size }}px;
    background-color: {{ block.settings.separator_color }};
    border-radius: 50%;
  }

  .ai-scrolling-header-{{ ai_gen_id }}:hover .ai-scrolling-header__wrapper-{{ ai_gen_id }} {
    animation-play-state: {% if block.settings.pause_on_hover %}paused{% else %}running{% endif %};
  }

  @keyframes ai-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-scrolling-header__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<scrolling-header-{{ ai_gen_id }}
  class="ai-scrolling-header-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-scrolling-header__wrapper-{{ ai_gen_id }}">
    {% for i in (1..2) %}
      <div class="ai-scrolling-header__item-{{ ai_gen_id }}">
        {% if block.settings.text_1 != blank %}
          <span class="ai-scrolling-header__text-{{ ai_gen_id }}">{{ block.settings.text_1 }}</span>
          {% if block.settings.show_separator %}
            <span class="ai-scrolling-header__separator-{{ ai_gen_id }}"></span>
          {% endif %}
        {% endif %}

        {% if block.settings.text_2 != blank %}
          <span class="ai-scrolling-header__text-{{ ai_gen_id }}">{{ block.settings.text_2 }}</span>
          {% if block.settings.show_separator %}
            <span class="ai-scrolling-header__separator-{{ ai_gen_id }}"></span>
          {% endif %}
        {% endif %}

        {% if block.settings.text_3 != blank %}
          <span class="ai-scrolling-header__text-{{ ai_gen_id }}">{{ block.settings.text_3 }}</span>
          {% if block.settings.show_separator %}
            <span class="ai-scrolling-header__separator-{{ ai_gen_id }}"></span>
          {% endif %}
        {% endif %}

        {% if block.settings.text_4 != blank %}
          <span class="ai-scrolling-header__text-{{ ai_gen_id }}">{{ block.settings.text_4 }}</span>
          {% if block.settings.show_separator %}
            <span class="ai-scrolling-header__separator-{{ ai_gen_id }}"></span>
          {% endif %}
        {% endif %}

        {% if block.settings.text_5 != blank %}
          <span class="ai-scrolling-header__text-{{ ai_gen_id }}">{{ block.settings.text_5 }}</span>
          {% if block.settings.show_separator %}
            <span class="ai-scrolling-header__separator-{{ ai_gen_id }}"></span>
          {% endif %}
        {% endif %}
      </div>
    {% endfor %}
  </div>
</scrolling-header-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollingHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-scrolling-header__wrapper-{{ ai_gen_id }}');
        this.adjustScrollSpeed();
      }

      adjustScrollSpeed() {
        if (!this.wrapper) return;
        
        const firstItem = this.wrapper.querySelector('.ai-scrolling-header__item-{{ ai_gen_id }}');
        if (!firstItem) return;
        
        const itemWidth = firstItem.offsetWidth;
        this.wrapper.style.width = `${itemWidth * 2}px`;
      }
    }

    customElements.define('scrolling-header-{{ ai_gen_id }}', ScrollingHeader{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Scrolling header",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Text 1",
      "default": "Free shipping on orders over $50"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Text 2",
      "default": "New arrivals every week"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Text 3",
      "default": "Shop now and save 20%"
    },
    {
      "type": "text",
      "id": "text_4",
      "label": "Text 4",
      "default": "Limited time offer"
    },
    {
      "type": "text",
      "id": "text_5",
      "label": "Text 5",
      "default": "Subscribe for exclusive deals"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "s",
      "label": "Scroll speed",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "label": "Letter spacing",
      "default": 1
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Vertical padding",
      "default": 15
    },
    {
      "type": "header",
      "content": "Separator"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Show separator",
      "default": true
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "separator_size",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Separator size",
      "default": 4
    },
    {
      "type": "range",
      "id": "item_spacing",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Item spacing",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Scrolling header"
    }
  ]
}
{% endschema %}
