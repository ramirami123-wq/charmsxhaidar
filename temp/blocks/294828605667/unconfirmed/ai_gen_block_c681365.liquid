{% doc %}
  @prompt
    COUNTDOWN TIMER FOR FREE BRACELET OFFER WITH DAYS:HRS:MINS:SECS, make the format like the one in section store
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-countdown-timer__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
  }

  .ai-countdown-timer__subtext-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing }}px 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
  }

  .ai-countdown-timer__display-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.separator_spacing }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-timer__unit-{{ ai_gen_id }} {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
  }

  .ai-countdown-timer__number-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: {{ block.settings.number_min_width }}px;
    padding: {{ block.settings.number_padding }}px;
    background-color: {{ block.settings.number_background }};
    color: {{ block.settings.number_color }};
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    border-radius: {{ block.settings.number_border_radius }}px;
    line-height: 1;
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    margin-top: {{ block.settings.label_spacing }}px;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    text-transform: {{ block.settings.label_transform }};
  }

  .ai-countdown-timer__separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    line-height: 1;
    padding-bottom: {{ block.settings.label_spacing }}px;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    color: {{ block.settings.expired_text_color }};
    font-size: {{ block.settings.text_size }}px;
    padding: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-countdown-timer__number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.8);
      min-width: calc({{ block.settings.number_min_width }}px * 0.8);
      padding: calc({{ block.settings.number_padding }}px * 0.8);
    }

    .ai-countdown-timer__separator-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.8);
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-countdown-timer__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.subtext != blank %}
    <div class="ai-countdown-timer__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
  {% endif %}

  <div class="ai-countdown-timer__display-{{ ai_gen_id }}" data-countdown-display>
    <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-days>00</div>
      <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.days_label }}</div>
    </div>

    {% if block.settings.show_separator %}
      <div class="ai-countdown-timer__separator-{{ ai_gen_id }}">:</div>
    {% endif %}

    <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-hours>00</div>
      <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</div>
    </div>

    {% if block.settings.show_separator %}
      <div class="ai-countdown-timer__separator-{{ ai_gen_id }}">:</div>
    {% endif %}

    <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-minutes>00</div>
      <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.minutes_label }}</div>
    </div>

    {% if block.settings.show_separator %}
      <div class="ai-countdown-timer__separator-{{ ai_gen_id }}">:</div>
    {% endif %}

    <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-seconds>00</div>
      <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.seconds_label }}</div>
    </div>
  </div>

  <div class="ai-countdown-timer__expired-{{ ai_gen_id }}" data-expired-message style="display: none;">
    {{ block.settings.expired_message }}
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.daysEl = this.querySelector('[data-days]');
        this.hoursEl = this.querySelector('[data-hours]');
        this.minutesEl = this.querySelector('[data-minutes]');
        this.secondsEl = this.querySelector('[data-seconds]');
        this.displayEl = this.querySelector('[data-countdown-display]');
        this.expiredEl = this.querySelector('[data-expired-message]');
        this.interval = null;
      }

      connectedCallback() {
        if (!this.endDate || !this.endTime) {
          this.showExpired();
          return;
        }

        this.updateCountdown();
        this.interval = setInterval(() => this.updateCountdown(), 1000);
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      updateCountdown() {
        const endDateTime = new Date(this.endDate + 'T' + this.endTime).getTime();
        const now = new Date().getTime();
        const distance = endDateTime - now;

        if (distance < 0) {
          this.showExpired();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        this.daysEl.textContent = String(days).padStart(2, '0');
        this.hoursEl.textContent = String(hours).padStart(2, '0');
        this.minutesEl.textContent = String(minutes).padStart(2, '0');
        this.secondsEl.textContent = String(seconds).padStart(2, '0');
      }

      showExpired() {
        if (this.interval) {
          clearInterval(this.interval);
        }
        this.displayEl.style.display = 'none';
        this.expiredEl.style.display = 'block';
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

