{% doc %}
  @prompt
    generate a video section just like the one in section store
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-block-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-video-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    padding-bottom: {{ block.settings.video_aspect_ratio }};
    height: 0;
    overflow: hidden;
  }

  .ai-video-wrapper-{{ ai_gen_id }} iframe,
  .ai-video-wrapper-{{ ai_gen_id }} video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .ai-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-video-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-video-cover-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .ai-video-play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    width: {{ block.settings.play_button_size }}px;
    height: {{ block.settings.play_button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.play_button_background }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, opacity 0.3s ease;
    opacity: {{ block.settings.play_button_opacity }};
  }

  .ai-video-play-button-{{ ai_gen_id }}:hover {
    transform: translate(-50%, -50%) scale(1.1);
    opacity: 1;
  }

  .ai-video-play-button-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.play_button_size }}px * 0.4);
    height: calc({{ block.settings.play_button_size }}px * 0.4);
    fill: {{ block.settings.play_button_icon_color }};
    margin-left: 4px;
  }

  .ai-video-play-button-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-video-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity }}) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .ai-video-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.content_padding }}px;
    left: {{ block.settings.content_padding }}px;
    right: {{ block.settings.content_padding }}px;
    z-index: 3;
    color: {{ block.settings.text_color }};
  }

  .ai-video-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 8px 0;
    font-weight: 700;
  }

  .ai-video-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0;
    opacity: 0.9;
  }

  .ai-video-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    z-index: 4;
  }

  @media screen and (max-width: 749px) {
    .ai-video-block-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-video-play-button-{{ ai_gen_id }} {
      width: calc({{ block.settings.play_button_size }}px * 0.8);
      height: calc({{ block.settings.play_button_size }}px * 0.8);
    }

    .ai-video-play-button-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.play_button_size }}px * 0.32);
      height: calc({{ block.settings.play_button_size }}px * 0.32);
    }

    .ai-video-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-video-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.8);
    }

    .ai-video-content-{{ ai_gen_id }} {
      bottom: calc({{ block.settings.content_padding }}px * 0.7);
      left: calc({{ block.settings.content_padding }}px * 0.7);
      right: calc({{ block.settings.content_padding }}px * 0.7);
    }
  }
{% endstyle %}

<video-block-{{ ai_gen_id }}
  class="ai-video-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-container-{{ ai_gen_id }}">
    <div class="ai-video-wrapper-{{ ai_gen_id }}">
      {% if block.settings.video_url != blank %}
        {% liquid
          assign video_id = ''
          assign video_type = ''

          if block.settings.video_url contains 'youtube.com' or block.settings.video_url contains 'youtu.be'
            assign video_type = 'youtube'
            if block.settings.video_url contains 'youtu.be/'
              assign video_id = block.settings.video_url | split: 'youtu.be/' | last | split: '?' | first
            elsif block.settings.video_url contains 'watch?v='
              assign video_id = block.settings.video_url | split: 'watch?v=' | last | split: '&' | first
            elsif block.settings.video_url contains 'embed/'
              assign video_id = block.settings.video_url | split: 'embed/' | last | split: '?' | first
            endif
          elsif block.settings.video_url contains 'vimeo.com'
            assign video_type = 'vimeo'
            assign video_id = block.settings.video_url | split: 'vimeo.com/' | last | split: '/' | first
          endif
        %}

        {% if video_type == 'youtube' and video_id != blank %}
          <iframe
            id="ai-video-iframe-{{ ai_gen_id }}"
            src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1&rel=0&modestbranding=1"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            title="{{ block.settings.heading | default: 'Video' }}"
          ></iframe>
        {% elsif video_type == 'vimeo' and video_id != blank %}
          <iframe
            id="ai-video-iframe-{{ ai_gen_id }}"
            src="https://player.vimeo.com/video/{{ video_id }}?title=0&byline=0&portrait=0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            title="{{ block.settings.heading | default: 'Video' }}"
          ></iframe>
        {% else %}
          <div class="ai-video-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-video-empty-state-{{ ai_gen_id }}">
              Next, add a valid YouTube or Vimeo URL
            </div>
          </div>
        {% endif %}

        {% if block.settings.cover_image and block.settings.show_cover_image %}
          <img
            id="ai-video-cover-{{ ai_gen_id }}"
            src="{{ block.settings.cover_image | image_url: width: 2000 }}"
            alt="{{ block.settings.cover_image.alt | escape }}"
            class="ai-video-cover-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.cover_image.width }}"
            height="{{ block.settings.cover_image.height }}"
          >

          <button
            id="ai-video-play-{{ ai_gen_id }}"
            class="ai-video-play-button-{{ ai_gen_id }}"
            aria-label="Play video"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
            >
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>
        {% endif %}
      {% else %}
        <div class="ai-video-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-video-empty-state-{{ ai_gen_id }}">
            Next, add a video URL
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_overlay %}
        <div class="ai-video-overlay-{{ ai_gen_id }}"></div>
      {% endif %}

      {% if block.settings.heading != blank or block.settings.subheading != blank %}
        <div class="ai-video-content-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-video-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.subheading != blank %}
            <p class="ai-video-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</video-block-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.playButton = this.querySelector('#ai-video-play-{{ ai_gen_id }}');
        this.coverImage = this.querySelector('#ai-video-cover-{{ ai_gen_id }}');
        this.iframe = this.querySelector('#ai-video-iframe-{{ ai_gen_id }}');
      }

      connectedCallback() {
        if (this.playButton && this.iframe) {
          this.playButton.addEventListener('click', () => this.playVideo());
        }
      }

      playVideo() {
        if (this.coverImage) {
          this.coverImage.style.opacity = '0';
          this.coverImage.style.transition = 'opacity 0.3s ease';
          setTimeout(() => {
            this.coverImage.style.display = 'none';
          }, 300);
        }

        if (this.playButton) {
          this.playButton.classList.add('hidden');
        }

        if (this.iframe) {
          const src = this.iframe.src;
          if (src.includes('youtube.com')) {
            this.iframe.src = src + '&autoplay=1';
          } else if (src.includes('vimeo.com')) {
            this.iframe.src = src + '&autoplay=1';
          }
        }
      }
    }

    customElements.define('video-block-{{ ai_gen_id }}', VideoBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Video",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL"
    },
    {
      "type": "select",
      "id": "video_aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "56.25%",
          "label": "16:9"
        },
        {
          "value": "75%",
          "label": "4:3"
        },
        {
          "value": "100%",
          "label": "1:1"
        },
        {
          "value": "125%",
          "label": "4:5"
        }
      ],
      "default": "56.25%"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Cover image"
    },
    {
      "type": "checkbox",
      "id": "show_cover_image",
      "label": "Show cover image",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Cover image"
    },
    {
      "type": "header",
      "content": "Play button"
    },
    {
      "type": "range",
      "id": "play_button_size",
      "label": "Size",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "color",
      "id": "play_button_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "play_button_icon_color",
      "label": "Icon color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "play_button_opacity",
      "label": "Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.9
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Video"
    }
  ]
}
{% endschema %}